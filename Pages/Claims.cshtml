@page
@model HealthInsuranceWeb.Pages.ClaimsModel
@{
    ViewData["Title"] = "Claims";
}

<section class="page-banner">
    <div class="container">
        <h1>Claim Process</h1>
        <p>Simple and transparent steps for cashless and reimbursement claims.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-title">
            <h2>Cashless Claim Process</h2>
        </div>

        <div class="steps-grid">
            <div class="step-card">
                <span>1</span>
                <h3>Visit Network Hospital</h3>
                <p>Choose a hospital from our approved network list.</p>
            </div>
            <div class="step-card">
                <span>2</span>
                <h3>Show Health Card</h3>
                <p>Provide your policy card and identity proof.</p>
            </div>
            <div class="step-card">
                <span>3</span>
                <h3>Pre-Authorization</h3>
                <p>The hospital sends the treatment request for approval.</p>
            </div>
            <div class="step-card">
                <span>4</span>
                <h3>Claim Settlement</h3>
                <p>Approved admissible expenses are settled directly.</p>
            </div>
        </div>

        <div class="section-title top-space">
            <h2>Required Documents</h2>
        </div>

        <div class="doc-box">
            <ul class="feature-list dark-list">
                <li>Policy/health card copy</li>
                <li>ID proof</li>
                <li>Doctor prescription</li>
                <li>Hospital discharge summary</li>
                <li>Original bills and reports for reimbursement claims</li>
            </ul>
        </div>
    </div>
</section>