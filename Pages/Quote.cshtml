@page
@model HealthInsuranceWeb.Pages.QuoteModel
@{
    ViewData["Title"] = "Get Quote";
}

<section class="page-banner">
    <div class="container">
        <h1>Get Your Free Health Insurance Quote</h1>
        <p>Fill in your details and our advisor team will contact you.</p>
    </div>
</section>

<section class="section">
    <div class="container quote-layout">
        <div class="quote-info">
            <h2>Why request a quote?</h2>
            <div class="info-card small-card">
                <h3>Customized Pricing</h3>
                <p>Premium estimates based on your age and coverage needs.</p>
            </div>
            <div class="info-card small-card">
                <h3>Expert Guidance</h3>
                <p>Compare the best policy options before buying.</p>
            </div>
            <div class="info-card small-card">
                <h3>Quick Response</h3>
                <p>Our team connects with you as soon as possible.</p>
            </div>
        </div>

        <div class="form-card">
            <h2>Request Quote</h2>

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="success-box">@Model.SuccessMessage</div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger validation-summary"></div>

                <div class="form-group">
                    <label asp-for="Input.FullName"></label>
                    <input asp-for="Input.FullName" class="form-control" placeholder="Enter full name" />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Age"></label>
                    <input asp-for="Input.Age" class="form-control" placeholder="Enter age" />
                    <span asp-validation-for="Input.Age" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.City"></label>
                    <input asp-for="Input.City" class="form-control" placeholder="Enter city" />
                    <span asp-validation-for="Input.City" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Mobile"></label>
                    <input asp-for="Input.Mobile" class="form-control" placeholder="Enter mobile number" />
                    <span asp-validation-for="Input.Mobile" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" class="form-control" placeholder="Enter email address" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.PlanType"></label>
                    <select asp-for="Input.PlanType" class="form-control">
                        <option value="">-- Select Plan --</option>
                        <option>Individual Care</option>
                        <option>Family Shield</option>
                        <option>Senior Secure</option>
                        <option>Corporate Health Plan</option>
                    </select>
                    <span asp-validation-for="Input.PlanType" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary full-width">Submit Quote Request</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}